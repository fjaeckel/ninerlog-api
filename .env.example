# =============================================================================
# NinerLog API — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables have sensible defaults for local development.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://ninerlog:changeme@localhost:5432/ninerlog?sslmode=disable

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
GIN_MODE=debug          # debug | release | test
LOG_LEVEL=info          # debug | info | warn | error

# -----------------------------------------------------------------------------
# Authentication — CHANGE THESE IN PRODUCTION
# -----------------------------------------------------------------------------
JWT_SECRET=change-this-secret-key-in-production
REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS (comma-separated origins)
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Database Migrations
# -----------------------------------------------------------------------------
MIGRATIONS_PATH=db/migrations

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# DISABLE_RATE_LIMIT=true   # Only set for testing

# -----------------------------------------------------------------------------
# SMTP / Email (optional — emails are logged to stdout when SMTP_HOST is empty)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@ninerlog.app

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# NOTIFICATION_CHECK_INTERVAL=1h   # Go duration string
